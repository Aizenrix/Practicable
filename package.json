{
  "name": "calipso-coffee",
  "version": "1.0.1",
  "description": "Calipso.Coffee order management system backend",
  "main": "src/server.js",
  "scripts": {
    "test": "node scripts/run_tests.js",
    "test:report": "node --test --test-reporter spec $(node -e \"const f=require('fs'),p=require('path');function w(d,a=[]){for(const e of f.readdirSync(d,{withFileTypes:true})){const x=p.join(d,e.name);if(e.isDirectory()&&e.name!=='load')w(x,a);else if(e.name.endsWith('.test.js'))a.push(x);}return a;}console.log(w('test').join(' '))\")",
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "node prisma/seed.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm test",
    "test:api": "node --test \"test/api/**/*.test.js\"",
    "test:smoke": "node --test \"test/smoke/**/*.test.js\"",
    "api-test": "node scripts/run_api_tests.js",
    "quality-check": "npm run check && npm run api-test",
    "test:security": "node --test \"test/security/**/*.test.js\"",
    "build": "npm run prisma:generate && node --check src/server.js && node --check src/app.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "prisma": "^6.7.0"
  }
}
