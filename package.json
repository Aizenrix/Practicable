{
  "name": "calipso-coffee",
  "version": "1.0.1",
  "description": "Calipso.Coffee order management system backend",
  "main": "src/server.js",
  "scripts": {
    "test": "node --test \"test/**/*.test.js\"",
    "test:report": "node --test --test-reporter spec \"test/**/*.test.js\"",
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "node prisma/seed.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm test",
    "test:api": "node --test \"test/api/**/*.test.js\"",
    "test:smoke": "node --test \"test/smoke/**/*.test.js\"",
    "api-test": "node scripts/run_api_tests.js",
    "quality-check": "npm run check && npm run api-test",
    "test:security": "node --test \"test/security/**/*.test.js\"",
    "build": "npm run prisma:generate && node --check src/server.js && node --check src/app.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "prisma": "^6.7.0"
  }
}
