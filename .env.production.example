# Production / demo-стенд Calipso.Coffee
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
PORT=4000

JWT_SECRET=change_me_in_real_environment
DATABASE_URL=file:/data/dev.db

LOG_LEVEL=info
NODE_ENV=production

# CORS: только доверенные origin (не * в production)
CORS_ORIGIN=http://localhost:4000

# Для VPS с Nginx укажите домен:
# ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
