{
  "info": {
    "name": "Calipso.Coffee API",
    "description": "Коллекция API-тестов этапа 4 УП.03",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Login success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('token', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"admin@calipso.coffee\",\"password\":\"admin123\"}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Login error",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"admin@calipso.coffee\",\"password\":\"wrong\"}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Get menu items",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/menu/items"
      }
    },
    {
      "name": "Unknown API route",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/unknown-route"
      }
    }
  ]
}
